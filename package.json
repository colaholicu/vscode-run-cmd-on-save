{
  "name": "run-cmd-on-save",
  "displayName": "Run on Save",
  "description": "Runs a command when a .ts or .scss file is saved.",
  "publisher": "colaholicu",
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Run On Save",
      "properties": {
        "run-cmd-on-save.command": {
          "type": "string",
          "default": "",
          "description": "Command to run on save."
        },
        "run-cmd-on-save.requiredCommonFile": {
          "type": "string",
          "default": "",
          "description": "If file is specified it will run the command in the folder where this file exists inside the saved file's tree."
        },
        "run-cmd-on-save.commandTimeout": {
          "type": "integer",
          "default": 5,
          "description": "Default timeout (in seconds) for the command before the process gets terminated."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/colaholicu/vscode-run-cmd-on-save.git"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.89.0",
    "@typescript-eslint/eslint-plugin": "^5.31.0",
    "@typescript-eslint/parser": "^5.31.0",
    "@vscode/test-electron": "^2.1.5",
    "eslint": "^8.20.0",
    "glob": "^8.0.3",
    "mocha": "^11.7.5",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "vsce": "^2.15.0"
  }
}

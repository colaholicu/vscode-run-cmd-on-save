{
  "name": "run-cmd-on-save",
  "displayName": "Run on Save",
  "description": "Runs a command when a .ts or .scss file is saved.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
			"title": "Run On Save",
			"properties": {
				"run-cmd-on-save.command": {
					"type": "string",
					"default": "",
					"description": "Command to run on save."
				},
				"run-cmd-on-save.requiredCommonFile": {
					"type": "string",
					"default": "",
					"description": "If file is specified it will run the command in the folder where this file exists inside the saved file's tree."
				}
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.89.0",
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.31.0",
    "@typescript-eslint/parser": "^5.31.0",
    "eslint": "^8.20.0",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "typescript": "^4.7.4",
    "@vscode/test-electron": "^2.1.5"
  }
}
